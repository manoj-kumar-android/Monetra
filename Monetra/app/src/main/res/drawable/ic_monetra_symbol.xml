<?xml version="1.0" encoding="utf-8"?>
<!--
    Monetra splash / launcher foreground icon.
    Viewport 108x108 (adaptive icon spec).
    The safe zone for the icon glyph is the inner 72x72 centred at (54,54).
    This draws a stylised ₹ rupee symbol in white.

    ₹ anatomy:
      - Vertical left stem
      - Two horizontal top bars
      - An arc/bulge on the right for the top bar
      - Diagonal slash going bottom-right
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        ₹ glyph centred in the 72x72 safe zone (18..90 x 18..90).
        Glyph is drawn at 34..74 x 26..82 for good visual weight.

        Elements:
        1. Left vertical stem   — x:34..40, y:26..82
        2. Top horiz bar 1      — x:34..74, y:26..33
        3. Second horiz bar     — x:34..74, y:39..46
        4. Right bump (arc)     — simple 2-path approximation of the curved top right
        5. Diagonal slash       — from ~(46,46) to (74,82)
    -->

    <!-- 1 · Left vertical stem -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M34,26 L41,26 L41,82 L34,82 Z" />

    <!-- 2 · Top horizontal bar -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M34,26 L74,26 L74,33 L34,33 Z" />

    <!-- 3 · Second horizontal bar -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M34,39 L74,39 L74,46 L34,46 Z" />

    <!--
        4 · Right-side rounded bump between the two bars.
        Approximated as a 180° arc (semi-circle) on the right side.
        Centre: x=57.5, y=36. Radius ~16. We draw it as a filled path.
    -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="
            M57,26
            C57,26 74,26 74,36
            C74,46 57,46 57,46
            Z
        " />

    <!-- 5 · Diagonal slash from second bar down to bottom-right -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M44,46 L74,82 L67,82 L37,46 Z" />

</vector>
