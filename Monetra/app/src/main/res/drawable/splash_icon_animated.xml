<?xml version="1.0" encoding="utf-8"?>
<!-- 
    Refined "m" logo for splash animations.
    Mathematically centered geometry.
-->
<animated-vector
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">

    <aapt:attr name="android:drawable">
        <vector
            android:width="108dp"
            android:height="108dp"
            android:viewportWidth="108"
            android:viewportHeight="108">

            <group
                android:name="m_group"
                android:pivotX="54"
                android:pivotY="54"
                android:scaleX="0.5"
                android:scaleY="0.5">
                <path
                    android:fillColor="#FFFFFFFF"
                    android:pathData="
                        M37,49
                        C37,42 41,38 47,38
                        C52,38 56,41 58,46
                        C60,41 64,38 69,38
                        C75,38 79,42 79,49
                        L79,69
                        L71,69
                        L71,52
                        C71,48 69,47 66,47
                        C62,47 58,52 58,59
                        L58,69
                        L50,69
                        L50,52
                        C50,48 48,47 45,47
                        C41,47 37,52 37,59
                        L37,69
                        L29,69
                        L29,54
                        C29,44 32,38 37,38
                        L37,49
                        Z
                    " />
            </group>
        </vector>
    </aapt:attr>

    <target android:name="m_group">
        <aapt:attr name="android:animation">
            <set android:ordering="together">
                <objectAnimator
                    android:propertyName="scaleX"
                    android:valueFrom="0.5"
                    android:valueTo="1.0"
                    android:duration="700"
                    android:interpolator="@android:interpolator/overshoot" />
                <objectAnimator
                    android:propertyName="scaleY"
                    android:valueFrom="0.5"
                    android:valueTo="1.0"
                    android:duration="700"
                    android:interpolator="@android:interpolator/overshoot" />
            </set>
        </aapt:attr>
    </target>

</animated-vector>
