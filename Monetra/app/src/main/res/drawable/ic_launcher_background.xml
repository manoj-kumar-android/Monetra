<?xml version="1.0" encoding="utf-8"?>
<!--
    Monetra — Premium Blue Icon Background v4
    Transitioned from navy/violet to a centered "Monetra Blue" theme.
    Colors derived directly from the app's primary palette (#007AFF).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Base: Deep blue to Monetra primary blue -->
    <path android:pathData="M0,0 L108,0 L108,108 L0,108 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0" android:startY="0"
                android:endX="108" android:endY="108">
                <item android:offset="0.0"  android:color="#FF003D8F" />
                <item android:offset="1.0"  android:color="#FF007AFF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Subtle radial glow for depth -->
    <path android:pathData="M0,0 L108,0 L108,108 L0,108 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54" android:centerY="54"
                android:gradientRadius="70">
                <item android:offset="0.0" android:color="#44FFFFFF" />
                <item android:offset="1.0" android:color="#00FFFFFF" />
            </gradient>
        </aapt:attr>
    </path>

</vector>
